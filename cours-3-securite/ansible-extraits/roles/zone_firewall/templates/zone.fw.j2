{#- Fichier de zone pve-firewall pour UNE VM : /etc/pve/firewall/<vmid>.fw #}
{#- Managed by Ansible (rôle zone_firewall) — ne pas modifier à la main.     #}
[OPTIONS]
enable: 1
policy_in: DROP

[RULES]
{% for rule in item.rules %}
{{ rule }}
{% endfor %}
IN ACCEPT -p icmp # ping autorisé (diagnostic)
