; Correction TP chap. 4 — fichier complet : roles/dns/templates/zone.j2
; Managed by Ansible — ne pas modifier manuellement
$TTL    604800
@       IN      SOA     dns-proxy.{{ dns_domain }}. admin.{{ dns_domain }}. (
                        {{ ansible_date_time.epoch }}  ; Serial
                        3600       ; Refresh
                        1800       ; Retry
                        604800     ; Expire
                        86400 )    ; Negative Cache TTL

@       IN      NS      dns-proxy.{{ dns_domain }}.

{% for record in dns_records %}
{{ record.name }}    IN      A       {{ record.ip }}
{% endfor %}

{# TP étape 2 : les surnoms. Après les A : un CNAME pointe vers un nom existant. #}
{% for c in dns_cnames %}
{{ c.name }}    IN      CNAME   {{ c.target }}
{% endfor %}
